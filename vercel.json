{
  "version": 2,
  "headers": [
    {
      "source": "/vibe-tools/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "builds": [
    {
      "src": "web/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/",
      "status": 307,
      "headers": {
        "Location": "/vibe-tools/index.html"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/web/$1"
    }
  ]
}
