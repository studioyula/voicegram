{
  "version": 2,
  "builds": [
    {
      "src": "web/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/",
      "status": 307,
      "headers": {
        "Location": "/vibe-tools/index.html"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/web/$1"
    }
  ]
}
